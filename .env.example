# Backend environment variables
# Copy to .env and fill in values

REDIS_URL=redis://redis:6379
MAX_CONCURRENT_JOBS=2
STORAGE_DIR=/storage
JOB_TTL_DAYS=7
PAGE_TIMEOUT_SEC=30
LLM_CALL_TIMEOUT_SEC=60
JOB_MAX_DURATION_SEC=1200
LOG_LEVEL=info

# NEVER set these as environment variables:
# - LLM API keys  (provided per request)
# - Auth credentials  (provided per request)
