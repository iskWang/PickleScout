    "fastify": "4.29.0",
    "ioredis": "5.4.2",
    "nanoid": "3.3.11",
    "openai": "4.97.0",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.50",
    "eslint": "8.57.1",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.4"
