    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "3.0.0",
    "@fastify/cors": "9.0.1",
    "@fastify/static": "^7.0.4",
    "archiver": "7.0.1",
    "bullmq": "5.51.1",
    "fastify": "4.29.0",
    "ioredis": "5.4.2",
    "nanoid": "3.3.11",
    "openai": "4.97.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/node": "20.17.50",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "8.57.1",
    "ts-node": "10.9.2",
    "vitest": "^2.1.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.4"
