{
  "name": "picklescout",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint":      "pnpm -r lint",
    "test":      "pnpm -r test",
    "build":     "pnpm -r build",
    "dev:backend":  "pnpm --filter @picklescout/backend dev",
    "dev:frontend": "pnpm --filter @picklescout/frontend dev"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@9.0.0"
}
